{
  "name": "badscientist",
  "private": true,
  "version": "0.1.0",
  "description": "Cross-platform SlyOS / AgentOS rebuild foundation for iOS, macOS, Linux, and Windows.",
  "type": "module",
  "workspaces": [
    "shared/agent-core",
    "platforms/desktop-shell",
    "platforms/desktop-agent"
  ],
  "scripts": {
    "agent": "npm run start -w @badscientist/desktop-agent",
    "apple:icons": "swift tools/apple/generate-icons.swift",
    "apple:sync-web": "node tools/apple/sync-web-assets.mjs",
    "apple:xcode": "node tools/apple/generate-xcode-project.mjs",
    "build": "npm run build --workspaces",
    "dev": "npm run dev -w @badscientist/desktop-shell",
    "db:check": "node tools/supabase/check-readiness.mjs",
    "db:apply": "node tools/supabase/apply-schema.mjs",
    "db:probe": "node tools/supabase/probe-live.mjs",
    "doctor": "node tools/diagnostics/doctor.mjs",
    "macos:app": "node tools/apple/build-macos-app.mjs",
    "release:all": "npm run release:web && npm run release:desktop-agent",
    "release:desktop-agent": "node tools/release/build-desktop-agent.mjs",
    "release:macos-app": "node tools/release/build-macos-app.mjs",
    "release:web": "node tools/release/build-web-pwa.mjs",
    "typecheck": "npm run typecheck --workspaces"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.13.0",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.2"
  }
}
